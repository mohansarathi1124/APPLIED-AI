beta1, beta2, epsilon = 0.9, 0.999, 1e-8


n_samples = X.shape[0]


for epoch in range(epochs):
# Shuffle for SGD / Mini-batch
indices = np.random.permutation(n_samples) X_shuffled = X[indices]
y_shuffled = y[indices]


# Decide batch size based on optimizer type
 
if optimizer_name == 'GD': current_batch_size = n_samples elif optimizer_name == 'SGD': current_batch_size = 1 else: current_batch_size = batch_size # MBGD and other for i in range(0, n_samples, current_batch_size):
X_batch = X_shuffled[i:i+current_batch_size] y_batch = y_shuffled[i:i+current_batch_size]

g = get_gradients(w, X_batch, y_batch) t += 1

# Apply standard updates (similar to Part 1) if optimizer_name in ['GD', 'SGD', 'MBGD']:
w -= lr * g
elif optimizer_name == 'Adam': m = beta1 * m + (1 - beta1) * g
sq_grad = beta2 * sq_grad + (1 - beta2) * g**2 m_hat = m / (1 - beta1**t)
v_hat = sq_grad / (1 - beta2**t)
w -= (lr / (np.sqrt(v_hat) + epsilon)) * m_hat


# Record at end of epoch loss = bce_loss(w, X, y)
history.append((w.copy().flatten(), loss))


return history


