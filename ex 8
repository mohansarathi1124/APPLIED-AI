np.random.seed(42)
X_class0 = np.random.randn(50, 2) * 0.2 + [0.5, 0.5] # Hands crossed (wrists close to shoulders) X_class1 = np.random.randn(50, 2) * 0.2 + [1.5, 1.5] # Hands up (wrists far from shoulders)
X = np.vstack([X_class0, X_class1])
y = np.vstack([np.zeros((50, 1)), np.ones((50, 1))]) #

def sigmoid(z):
return 1 / (1 + np.exp(-z))
 
def bce_loss(w, X, y): z = np.dot(X, w) y_hat = sigmoid(z)
# Clip to prevent log(0)
y_hat = np.clip(y_hat, 1e-15, 1 - 1e-15)
return -np.mean(y * np.log(y_hat) + (1 - y) * np.log(1 - y_hat))


def get_gradients(w, X_batch, y_batch): y_hat = sigmoid(np.dot(X_batch, w))
return np.dot(X_batch.T, (y_hat - y_batch)) / len(y_batch)


# 2. Mini-Batch Training Loop
def train_logistic_regression(optimizer_name, start_w, X, y, epochs=50, lr=0.1, batch_size=16): w = np.array(start_w, dtype=np.float64).reshape(2, 1)
